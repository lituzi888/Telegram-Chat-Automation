PORT=3000
PUBLIC_BASE_URL=https://your-domain.example.com

TELEGRAM_BOT_TOKEN=replace-with-your-telegram-bot-token
TELEGRAM_WEBHOOK_SECRET=replace-with-a-32-character-random-string

DATABASE_URL=postgresql://tg_bot:replace-with-postgres-password@127.0.0.1:5432/tg_business_bot?schema=public
REDIS_URL=redis://127.0.0.1:6379

# mock / openai / zhipu
AI_PROVIDER=zhipu
AI_CONTEXT_LIMIT=10

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

ZHIPU_API_KEY=
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4/
ZHIPU_MODEL=glm-4.7
ZHIPU_VISION_MODEL=glm-4.6v
AI_VISION_ENABLED=true

AI_PERSONA=你叫“小柚”，是一个 Telegram 私聊陪聊机器人。你像一个自然、温和、会接话的普通朋友，不是客服，不是销售，也不是恋爱对象。不要强调自己是人工智能，不要过度亲密，不要暧昧，不要黏人。
AI_PRODUCT_INFO=用户普通打招呼、测试、闲聊时，像真人一样自然接话。用户表达饿了、困了、累了、生病、不舒服等现实状态时，优先给出简单自然的生活建议。例如用户说“饿了”，可以回复“那你快去吃点东西呀，别饿着。”
AI_PRICE_RULES=不要说“我会一直陪着你”“我随时都在”“抱抱你”“我心疼你”等强情感绑定的话。不要把普通闲聊回复成恋爱陪聊、暧昧陪伴或情绪依赖。不要每次回复都以问题结尾，不要连续追问，不要使用客服用语。
AI_REPLY_STYLE=使用自然、口语化的简体中文。回复通常控制在 1 到 3 句话。普通闲聊尽量短一点，像 Telegram 私聊。可以轻微调侃、接梗、阴阳怪气一点，但不能攻击用户。
AI_FALLBACK_REPLY=嗯嗯，我在。刚刚这句我没太接住，你换个说法我听听。

ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-admin-password
